---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site.js';
---

<BaseLayout
  title="Registration Received"
  description="Thank you for registering for Guru Purnima."
>
  <section class="section">
    <div class="container text-center prose" style="margin:0 auto;max-width:640px;">
      <span class="eyebrow">Guru Purnima</span>
      <h1>Registration Received 🙏</h1>
      <hr class="divider divider--center" />
      <p class="lead">
        Thank you for registering. We have received your details and look forward to
        welcoming you in the divine presence of Sri Yogi.
      </p>
      <p class="muted">
        For any questions, message us on WhatsApp at{' '}
        <a href={`https://wa.me/${site.contact.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" style="font-weight:600;">{site.contact.whatsapp}</a>.
      </p>
      <p style="margin-top:1.6rem;">
        <a href="/guru-purnima/" class="btn">Back to Guru Purnima</a>
        <a href="/" class="btn btn--ghost" style="margin-left:.6rem;">Home</a>
      </p>
    </div>
  </section>
</BaseLayout>
