---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { site, book, bookRating, bookReviews, bookReviewsUrl, bookEndorsements, biography, biographyEndorsements } from '../data/site.js';

// Book page shows a brief set; the Home page leads with the fuller set.
const rating = bookRating;
const reviewsUrl = bookReviewsUrl;
const endorsements = bookEndorsements;
const reviews = bookReviews.slice(0, 3);

// ── Synopsis (from the book proposal) ─────────────────────────────────────
const synopsis = [
  'The Wanderer Who Owns the World is a layered, soul-driven journey through the stages and mysteries of human life. Drawing from ancient Indian philosophy, personal insight, and elemental experience, the book moves through nine sections — each peeling back a different layer of what it means to live, to feel, to seek, and ultimately, to remember.',
  'It begins with conception — not just biological, but cosmic. From there it dives into the quiet pulse of reality itself, where nature, time, and the divine hum just beneath ordinary things. Passion and desire arrive next, not as problems to fix, but as truths to feel. Purpose follows — not in grand declarations, but in the quiet rituals of caregiving, food, water, and breath.',
  'Stories come next — of saints, seekers, and the everyday sacred — carrying teachings not through sermons, but through feeling. The final chapters turn inward: to subtle practices, moments of truth, and glimpses of freedom. Yoga is no longer posture — it becomes presence. Samadhi is not a goal but a homecoming.',
  'This is not a book about owning anything in the usual sense. It is about the kind of ownership that comes from letting go — a return to what you never lost.',
];

// ── The nine sections (content outline) ───────────────────────────────────
const sections = [
  'Explores existence from conception to death through metaphysics, biology, and conscious awareness as a path to self-realisation.',
  'A poetic meditation on the underlying cosmic order (Ṛta), the play of Prakṛti, and the veiled yet intimate nature of Ātman and Brahman.',
  'Embodies intense physical and emotional longing, invoking the Aṣṭarāgās and questioning societal constructs through a lens of dynamic rebirth.',
  'Illuminates the spiritual dimension in everyday acts — caregiving, rituals, and bodily processes — through Apāna Vāyu, Dharma, and Śaucha.',
  'Presents Vāstu Śāstra and Jyotiṣa as frameworks for harmonising with cosmic and ecological rhythms.',
  'Uses allegorical storytelling to highlight virtues like humility and compassion, framing life’s trials as opportunities for transcendence.',
  'Describes devotion as visceral and lived, where lineage and guru are internalised through ancestral memory and subtle presence.',
  'Portrays temples, rituals, and symbols as living structures that activate inner transformation — with Nāgas, Siddhis, and granthis as metaphysical mechanics.',
  'Depicts liberation not as an external goal but as an inner unveiling, where the self sheds its layers and becomes a quiet channel for presence and light.',
];

// ── Who this book is for ──────────────────────────────────────────────────
const audience = [
  'You practise yoga, sit in meditation, or walk with spiritual questions close to your heart.',
  'You are drawn to sacred texts, poetry, and wisdom felt in the body as much as understood in the mind.',
  'Your spiritual insight has come not from books alone but through lived experience.',
  'You are recovering from rigid beliefs and seeking a more open, honest, intuitive path.',
];
const comparativeTitles = 'Braiding Sweetgrass by Robin Wall Kimmerer · The Prophet by Kahlil Gibran · Women Who Run with the Wolves by Clarissa Pinkola Estés · Pilgrim at Tinker Creek by Annie Dillard';
---

<BaseLayout title="Book" description={`${book.title} — a philosophical self-help work by ${book.author}, published by ${book.publisher}.`}>
  <PageHeader
    eyebrow="By Sri Yogi"
    title="The Book"
    lead="Drawing on ancient Indian wisdom — the paradox of owning the world only by ceasing to cling to it."
  />

  <section class="section">
    <div class="container book-layout">
      <div class="book-cover">
        <img src={book.cover} alt={`Cover of ${book.title} by ${book.author}`} />
      </div>

      <div class="book-info">
        <h2>{book.title}</h2>
        <p class="muted" style="font-size:1.05rem;">{book.subtitle}</p>
        <hr class="divider" />

        <p>
          This philosophical self-help work explores human existence through the lens
          of ancient Indian wisdom. {book.author} presents the paradoxical notion that
          true freedom emerges through non-attachment rather than possession — the
          realization that one owns the world only when one ceases to cling to it.
        </p>
        <p>
          Drawing on spiritual philosophy and lived insight, the book guides readers
          toward deeper self-understanding and purposeful living. It is written for
          seekers of meaning, stillness and truth — for anyone who has sensed a quiet
          inner knowing but lacked the words to express it.
        </p>

        <dl class="book-meta">
          <div><dt>Author</dt><dd>{book.author}</dd></div>
          <div><dt>Publisher</dt><dd>{book.publisher}</dd></div>
          <div><dt>Published</dt><dd>{book.published}</dd></div>
          <div><dt>Pages</dt><dd>{book.pages}</dd></div>
          <div><dt>ISBN</dt><dd>{book.isbn}</dd></div>
        </dl>

        <p style="margin-top:1.6rem;">
          <a href={book.amazonUrl} class="btn" target="_blank" rel="noopener">Buy on Amazon</a>
          <a href={book.penguinUrl} class="btn btn--ghost" style="margin-left:.6rem;" target="_blank" rel="noopener">View on Penguin</a>
        </p>
      </div>
    </div>
  </section>

  <!-- SYNOPSIS -->
  <section class="section section--tint">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">Synopsis</span>
        <h2>A Journey Through the Mysteries of Life</h2>
        <hr class="divider divider--center" />
      </div>
      <div class="prose" style="max-width:760px;margin:0 auto;">
        {synopsis.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <!-- THE NINE SECTIONS -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">Inside the Book</span>
        <h2>The Nine Sections</h2>
        <hr class="divider divider--center" />
        <p class="lead" style="max-width:700px;margin:0 auto;">
          Each of the book’s nine sections peels back a different layer of human
          experience — from conception to liberation.
        </p>
      </div>
      <ol class="sections-list">
        {sections.map((text) => <li>{text}</li>)}
      </ol>
    </div>
  </section>

  <!-- WHO THIS BOOK IS FOR -->
  <section class="section section--tint">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">Who This Book Is For</span>
        <h2>For the Seeker in You</h2>
        <hr class="divider divider--center" />
        <p class="lead" style="max-width:720px;margin:0 auto 1.5rem;">
          This book is for those who are searching — for meaning, for stillness, for
          something true. Not just spiritual seekers, but anyone who has ever felt a
          quiet knowing they couldn’t put into words.
        </p>
      </div>
      <div class="prose" style="max-width:680px;margin:0 auto;text-align:left;">
        <p>This book may speak to you if:</p>
        <ul>
          {audience.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <p class="text-center muted" style="max-width:720px;margin:1.5rem auto 0;font-style:italic;">
        It does not tell you what to believe — it reminds you that you already know.
      </p>
      <p class="text-center muted" style="max-width:720px;margin:1rem auto 0;font-size:0.9rem;">
        Readers who love {comparativeTitles} may feel at home in its pages.
      </p>
    </div>
  </section>

  <!-- WHAT READERS SAY -->
  <section class="section section--tint">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">What Readers Say</span>
        <h2>Reader Reviews</h2>
        <hr class="divider divider--center" />
        <div class="rating-badge">
          <span class="rating-badge__stars" aria-hidden="true">★★★★★</span>
          <strong>{rating.stars.toFixed(1)}</strong>
          <span class="muted">· {rating.count} ratings on Amazon</span>
        </div>
      </div>

      {endorsements.map((e) => (
        <figure class="endorsement">
          <span class="endorsement__mark" aria-hidden="true">“</span>
          <blockquote>{e.quote}</blockquote>
          <figcaption>
            <span class="endorsement__name">{e.name}</span>
            <span class="endorsement__source">{e.source}</span>
          </figcaption>
        </figure>
      ))}

      <div class="review-grid">
        {reviews.map((r) => (
          <figure class="review-card">
            <span class="review-card__source">{r.source}</span>
            <h3>{r.title}</h3>
            <blockquote>{r.quote}</blockquote>
            {r.name && <figcaption>— {r.name}</figcaption>}
          </figure>
        ))}
      </div>

      <p class="text-center" style="margin-top:2rem;">
        <a href={reviewsUrl} class="btn btn--ghost" target="_blank" rel="noopener">Read all reviews on Amazon</a>
      </p>
    </div>
  </section>

  <!-- BIOGRAPHY: THE WALK WITHIN THE FIRE -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">Also About Sri Yogi — The Biography</span>
        <h2>{biography.title}</h2>
        <p class="muted" style="max-width:720px;margin:0.4rem auto 0;">by {biography.author}</p>
        <hr class="divider divider--center" />
        <p class="lead" style="max-width:720px;margin:0 auto;">{biography.subtitle}</p>
      </div>

      <div class="bio-layout">
        <div class="bio-covers">
          <figure>
            <img src={biography.coverEn} alt={`Cover of ${biography.title} (English edition)`} />
            <figcaption>English</figcaption>
          </figure>
          <figure>
            <img src={biography.coverKn} alt={`Cover of the Kannada edition, ${biography.kannadaTitleRoman}`} />
            <figcaption>ಕನ್ನಡ · {biography.kannadaTitleRoman}</figcaption>
          </figure>
        </div>

        <div class="bio-info">
          <p class="bio-epigraph">{biography.epigraph}</p>
          <div class="prose">
            {biography.intro.map((p) => <p>{p}</p>)}
          </div>
          <dl class="book-meta">
            <div><dt>Author</dt><dd>{biography.author}</dd></div>
            <div><dt>Editions</dt><dd>English · Kannada ({biography.kannadaTitleRoman})</dd></div>
            <div><dt>Publisher</dt><dd>{biography.publisher}</dd></div>
            <div><dt>Price</dt><dd>{biography.price}</dd></div>
            <div><dt>ISBN</dt><dd>{biography.isbnEn} (EN) · {biography.isbnKn} (KN)</dd></div>
          </dl>

          <div class="bio-order">
            <h3>How to get a copy</h3>
            <p>{biography.availability}</p>
            <p class="bio-order__cta">
              <a class="btn" href={`https://wa.me/${site.contact.whatsapp.replace(/[^0-9]/g, '')}?text=${encodeURIComponent('Namaste 🙏 I would like to order a copy of “The Walk Within the Fire”.')}`} target="_blank" rel="noopener">Enquire on WhatsApp</a>
              <a class="btn btn--ghost" href={`mailto:${site.contact.email}?subject=${encodeURIComponent('Order: The Walk Within the Fire')}`} style="margin-left:.6rem;">Email us</a>
            </p>
          </div>
        </div>
      </div>

      {biographyEndorsements.map((e) => (
        <figure class="endorsement">
          <span class="endorsement__mark" aria-hidden="true">“</span>
          <blockquote>{e.quote}</blockquote>
          <figcaption>
            <span class="endorsement__name">{e.name}</span>
            <span class="endorsement__source">{e.source}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .book-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 3rem;
    align-items: start;
  }
  .book-cover img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    border: 1px solid var(--line);
  }
  .book-meta {
    margin: 1.5rem 0 0;
    display: grid;
    gap: 0.5rem;
  }
  .sections-list {
    list-style: none;
    counter-reset: sec;
    margin: 2rem auto 0;
    max-width: 820px;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .sections-list li {
    counter-increment: sec;
    position: relative;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.1rem 1.3rem 1.1rem 3.6rem;
    box-shadow: var(--shadow);
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .sections-list li::before {
    content: counter(sec);
    position: absolute;
    left: 1.1rem;
    top: 1rem;
    width: 1.8rem;
    height: 1.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--saffron);
    color: #fff;
    font-family: var(--font-head);
    font-size: 0.95rem;
    font-weight: 700;
  }
  .book-meta div { display: flex; gap: 0.6rem; }
  .book-meta dt { font-weight: 600; color: var(--saffron-dark); min-width: 90px; }
  .book-meta dd { margin: 0; color: var(--ink-soft); }

  /* Biography section */
  .bio-layout {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 2.5rem;
  }
  .bio-covers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    position: sticky;
    top: 1.5rem;
  }
  .bio-covers figure { margin: 0; text-align: center; }
  .bio-covers img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    border: 1px solid var(--line);
  }
  .bio-covers figcaption {
    margin-top: 0.5rem;
    font-size: 0.82rem;
    color: var(--ink-soft);
  }
  .bio-epigraph {
    font-family: var(--font-head);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--saffron-dark);
    border-left: 3px solid var(--saffron);
    padding-left: 1.1rem;
    margin: 0 0 1.5rem;
  }
  .bio-info .book-meta { margin-top: 1.8rem; }
  .bio-order {
    margin-top: 1.8rem;
    background: var(--tint, #faf6ef);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.3rem 1.5rem;
  }
  .bio-order h3 { margin: 0 0 0.4rem; }
  .bio-order p { margin: 0; color: var(--ink-soft); }
  .bio-order__cta { margin-top: 1rem !important; }

  @media (max-width: 720px) {
    .book-layout { grid-template-columns: 1fr; gap: 1.8rem; }
    .book-cover { max-width: 280px; margin: 0 auto; }
    .bio-layout { grid-template-columns: 1fr; gap: 1.8rem; }
    .bio-covers { position: static; max-width: 360px; margin: 0 auto; }
  }
</style>
