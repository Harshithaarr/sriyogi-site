---
import { site, nav } from '../data/site.js';
const { pathname } = Astro.url;
const isActive = (href) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={site.name}>
      <img src={site.logo} alt={site.name} class="brand-logo" width="1563" height="920" fetchpriority="high" />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Primary">
      {nav.map((item) => (
        <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(28, 25, 22, 0.94);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(203, 162, 86, 0.28);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.7rem;
    padding-bottom: 0.7rem;
    max-width: none;     /* full-width bar: brand pinned left, menu pinned right */
    padding-left: 2rem;
    padding-right: 2rem;
  }
  /* Gold logo sits directly on the dark bar and glows. */
  .brand { display: flex; align-items: center; }
  .brand:hover { text-decoration: none; }
  .brand-logo {
    height: 74px;
    width: auto;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }
  @media (max-width: 600px) {
    .brand-logo { height: 54px; }
  }

  .site-nav { display: flex; flex-wrap: nowrap; gap: 0.1rem; }
  .site-nav a {
    position: relative;
    color: #efe6d6;
    font-weight: 500;
    font-size: 0.9rem;
    padding: 0.5rem 0.6rem;
    border-radius: 8px;
    white-space: nowrap;
    transition: color 0.25s ease;
  }
  /* animated gradient underline */
  .site-nav a::after {
    content: '';
    position: absolute;
    left: 0.6rem; right: 0.6rem; bottom: 0.18rem;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--saffron), var(--gold));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.28s cubic-bezier(.22,1,.36,1);
  }
  .site-nav a:hover { color: var(--gold); text-decoration: none; }
  .site-nav a:hover::after { transform: scaleX(1); }
  .site-nav a.active { color: var(--gold); }
  .site-nav a.active::after { transform: scaleX(1); }

  .nav-burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 0.4rem; }
  .nav-burger span { width: 26px; height: 2.5px; background: var(--gold); border-radius: 2px; }

  @media (max-width: 1080px) {
    .nav-burger { display: flex; }
    .site-nav {
      display: none;
      position: absolute;
      left: 0; right: 0;
      top: 100%;
      flex-direction: column;
      flex-wrap: wrap;
      gap: 0;
      background: rgba(28, 25, 22, 0.98);
      border-bottom: 1px solid rgba(203, 162, 86, 0.28);
      padding: 0.5rem 1.25rem 1rem;
    }
    .nav-toggle:checked ~ .site-nav { display: flex; }
    .site-nav a { padding: 0.7rem 0.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
    .site-nav a::after { display: none; }
  }
</style>
